 teff_bins: int = 10,\n    mh_bins: int = 10,\n) -> np.ndarray:\n    \"\"\"\n    Selects a stratified test sample from the test window [test_start, test_end]\n    by partitioning (LOGG, TEFF, M_H) space into a 3D histogram and picking\n    the median-SNR star from each occupied bin.\n\n    Guarantees coverage of sparse regions that a random sample would miss,\n    while remaining representative of the overall distribution.\n\n    Args:\n        h5_path:         Path to the APOGEE HDF5 file.\n        stats_path:      Path to the saved normalisation stats (.npz).\n        selected_labels: Ordered list of label names (must match training order).\n        test_start:      First index of the test window in the HDF5 file.\n        test_end:        Last index (exclusive) of the test window.\n        target_n:        Desired test set size (default 500).\n        logg_bins:       Number of bins along LOGG axis.\n        teff_bins:       Number of bins along TEFF axis.\n        mh_bins:         Number of bins along M_H axis.\n\n    Returns:\n        selected_indices: 1D array of global HDF5 indices for the selected stars,\n                          sorted in ascending order.\n    \"\"\"\n\n    max_bins = logg_bins * teff_bins * mh_bins\n    if target_n > max_bins:\n        raise ValueError(\n            f\"target_n ({target_n}) exceeds the number of bins \"\n            f\"({logg_bins}x{teff_bins}x{mh_bins} = {max_bins}). \"\n            f\"Reduce target_n or increase bin counts.\"\n        )\n\n    # ------------------------------------------------------------------\n    # 1. Load raw labels for the test window (no imputation needed for\n    #    binning — we only need TEFF, LOGG, M_H which are rarely missing)\n    # ------------------------------------------------------------------\n    teff_idx = selected_labels.index('TEFF')\n    logg_idx = selected_labels.index('LOGG')\n    mh_idx   = selected_labels.index('M_H')\n\n    print(f\"Loading test window [{test_start}:{test_end}] \"\n          f\"({test_end - test_start} stars)...\")\n\n    with h5py.File(h5_path, 'r') as f:\n        meta  = f['metadata']\n        teff  = meta['TEFF'][test_start:test_end].astype(np.float32)\n        logg  = meta['LOGG'][test_start:test_end].astype(np.float32)\n        m_h   = meta['M_H'][test_start:test_end].astype(np.float32)\n        snr   = meta['SNR'][test_start:test_end].astype(np.float32)\n\n    n_test = test_end - test_start\n\n    # ------------------------------------------------------------------\n    # 2. Mask out sentinel values (-9999 etc.) so they don't pollute bins.\n    #    Stars with masked parameters will never be selected as bin medians\n    #    but are still present in the pool for fallback sampling.\n    # ------------------------------------------------------------------\n    SENTINEL = -5000.0\n    valid = (teff > SENTINEL) & (logg > SENTINEL) & (m_h > SENTINEL)\n    print(f\"  Valid stars (no sentinel values): {valid.sum()} / {n_test}\")\n\n    # ------------------------------------------------------------------\n    # 3. Define bin edges from the valid population.\n    #    Using percentile-based edges so each axis has roughly equal\n    #    occupancy in the training distribution (more robust than linspace\n    #    for skewed distributions like LOGG).\n    # ------------------------------------------------------------------\n    def percentile_edges(values, mask, n_bins):\n        pts = np.linspace(0, 100, n_bins + 1)\n        edges = np.percentile(values[mask], pts)\n        # Ensure strict monotonicity in case of ties at extremes\n        edges[0]  -= 1e-6\n        edges[-1] += 1e-6\n        return edges\n\n    logg_edges = percentile_edges(logg, valid, logg_bins)\n    teff_edges = percentile_edges(teff, valid, teff_bins)\n    mh_edges   = percentile_edges(m_h,  valid, mh_bins)\n\n    print(f\"  LOGG edges: {np.round(logg_edges, 2)}\")\n    print(f\"  TEFF edges: {np.round(teff_edges, 0)}\")\n    print(f\"  M_H  edges: {np.round(mh_edges,  2)}\")\n\n    # ------------------------------------------------------------------\n    # 4. Assign each valid star to a bin.\n    #    np.digitize returns 1-based indices; subtract 1 for 0-based,\n    #    then clip to [0, n_bins-1] to handle edge values.\n    # ------------------------------------------------------------------\n    logg_bin = np.clip(np.digitize(logg, logg_edges) - 1, 0, logg_bins - 1)\n    teff_bin = np.clip(np.digitize(teff, teff_edges) - 1, 0, teff_bins - 1)\n    mh_bin   = np.clip(np.digitize(m_h,  mh_edges)  - 1, 0, mh_bins  - 1)\n\n    # ------------------------------------------------------------------\n    # 5. For each occupied bin, pick the star closest to the median SNR.\n    #    \"Median star\" = the star whose SNR is nearest to the bin's median\n    #    SNR. This is more stable than picking by label value (which could\n    #    pick an outlier at the edge of the bin).\n    # ------------------------------------------------------------------\n    local_indices_selected = []   # indices relative to test window\n    bin_summary = []\n\n    for i in range(logg_bins):\n        for j in range(teff_bins):\n            for k in range(mh_bins):\n\n                # Find all valid stars in this bin\n                in_bin = valid & (logg_bin == i) & (teff_bin == j) & (mh_bin == k)\n                bin_local_idx = np.where(in_bin)[0]\n\n                if len(bin_local_idx) == 0:\n                    continue  # empty bin — skip\n\n                # Pick the star closest to the median SNR of this bin\n                bin_snr    = snr[bin_local_idx]\n                median_snr = np.median(bin_snr)\n                closest    = bin_local_idx[np.argmin(np.abs(bin_snr - median_snr))]\n\n                local_indices_selected.append(closest)\n                bin_summary.append({\n                    'bin': (i, j, k),\n                    'n_stars': len(bin_local_idx),\n                    'median_snr': median_snr,\n                    'selected_snr': snr[closest],\n                })\n\n    local_indices_selected = np.array(local_indices_selected)\n    n_from_bins = len(local_indices_selected)\n    print(f\"\\n  Occupied bins: {n_from_bins} / {max_bins}\")\n\n    # ------------------------------------------------------------------\n    # 6. If occupied bins gave fewer than target_n stars, top up by\n    #    random sampling from the remaining valid stars.\n    #    If occupied bins gave MORE than target_n, downsample by keeping\n    #    one star per bin preferring bins with the fewest members\n    #    (preserving sparse-region coverage).\n    # ------------------------------------------------------------------\n    if n_from_bins < target_n:\n        shortfall = target_n - n_from_bins\n        already_selected = set(local_indices_selected.tolist())\n        remaining = np.array([\n            idx for idx in np.where(valid)[0]\n            if idx not in already_selected\n        ])\n        if len(remaining) < shortfall:\n            print(f\"  Warning: only {len(remaining)} additional valid stars \"\n                  f\"available; test set will be smaller than target_n.\")\n            shortfall = len(remaining)\n\n        rng = np.random.default_rng(42)\n        extra = rng.choice(remaining, size=shortfall, replace=False)\n        local_indices_selected = np.concatenate([local_indices_selected, extra])\n        print(f\"  Topped up with {shortfall} random valid stars \"\n              f\"to reach {len(local_indices_selected)} total.\")\n\n    elif n_from_bins > target_n:\n        # Sort bins by occupancy ascending (keep sparsest regions)\n        # then take the first target_n\n        occupancies = np.array([b['n_stars'] for b in bin_summary])\n        order = np.argsort(occupancies)          # sparsest bins first\n        keep  = order[:target_n]\n        local_indices_selected = local_indices_selected[keep]\n        print(f\"  Downsampled from {n_from_bins} to {target_n}, \"\n              f\"prioritising sparse bins.\")\n\n    # ------------------------------------------------------------------\n    # 7. Convert local (test-window) indices to global HDF5 indices\n    # ------------------------------------------------------------------\n    global_indices = np.sort(local_indices_selected + test_start)\n\n    # ------------------------------------------------------------------\n    # 8. Print a brief summary\n    # ------------------------------------------------------------------\n    selected_teff = teff[global_indices - test_start]\n    selected_logg = logg[global_indices - test_start]\n    selected_mh   = m_h[global_indices  - test_start]\n    selected_snr  = snr[global_indices  - test_start]\n\n    print(f\"\\n{'='*50}\")\n    print(f\"  Final test set: {len(global_indices)} stars\")\n    print(f\"  TEFF  — min: {selected_teff.min():.0f}  \"\n               f\"max: {selected_teff.max():.0f}  \"\n               f\"median: {np.median(selected_teff):.0f}\")\n    print(f\"  LOGG  — min: {selected_logg.min():.2f}  \"\n               f\"max: {selected_logg.max():.2f}  \"\n               f\"median: {np.median(selected_logg):.2f}\")\n    print(f\"  [M/H] — min: {selected_mh.min():.2f}   \"\n               f\"max: {selected_mh.max():.2f}   \"\n               f\"median: {np.median(selected_mh):.2f}\")\n    print(f\"  SNR   — min: {selected_snr.min():.1f}   \"\n               f\"max: {selected_snr.max():.1f}   \"\n               f\"median: {np.median(selected_snr):.1f}\")\n    print(f\"{'='*50}\\n\")\n\n    return global_indices\n\n\ndef load_test_spectra(h5_path, global_indices):\n    \"\"\"\n    Loads flux and ivar for the selected test stars.\n\n    Args:\n        h5_path:        Path to the APOGEE HDF5 file.\n        global_indices: 1D array of global HDF5 indices (sorted).\n\n    Returns:\n        flux: (N, 8575) float32 array\n        ivar: (N, 8575) float32 array\n    \"\"\"\n    with h5py.File(h5_path, 'r') as f:\n        # HDF5 fancy indexing requires a sorted list\n        flux = f['flux'][global_indices].astype(np.float32)\n        ivar = f['ivar'][global_indices].astype(np.float32)\n    return flux, ivar\n\n\n# --- Usage ---\nif __name__ == \"__main__\":\n    TEST_START = 140_000\n    TEST_END   = 149_500\n\n    global_indices = select_stratified_test_sample(\n        h5_path        = config.H5_PATH,\n        stats_path     = config.STATS_PATH,\n        selected_labels= config.SELECTED_LABELS,\n        test_start     = TEST_START,\n        test_end       = TEST_END,\n        target_n       = 320,\n        logg_bins      = 5,\n        teff_bins      = 8,\n        mh_bins        = 8,\n    )\n\n    # Save indices for reproducibility\n    np.save(\"test_indices.npy\", global_indices)\n    print(f\"Saved {len(global_indices)} test indices to test_indices.npy\")\n\n    # Load corresponding spectra\n    flux, ivar = load_test_spectra(config.H5_PATH, global_indices)\n    print(f\"Flux shape: {flux.shape}, IVAR shape: {ivar.shape}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-13T13:36:45.163007Z","iopub.execute_input":"2026-03-13T13:36:45.163681Z","iopub.status.idle":"2026-03-13T13:37:06.976037Z","shell.execute_reply.started":"2026-03-13T13:36:45.163644Z","shell.execute_reply":"2026-03-13T13:37:06.975156Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import tensorflow as tf\nimport tensorflow_probability as tfp\ntfb = tfp.bijectors\n\n# Ordered exactly as your SELECTED_LABELS\nlower_bounds = [\n    # Core\n    3000.0, -0.5, -2.5,  0.0,  0.0,   0.0,  \n    # CNO\n    -1.5,  -1.0, -1.0, \n    # Metals\n    -2.5,  -1.5, -1.0, -1.0, -1.5, -1.0, \n    -1.5,  -1.5, -1.5, -4.0, -2.5, -4.5, \n    -2.5,  -2.5\n]\n\nupper_bounds = [\n    # Core\n    20000.0, 5.0,  1.0,  3.0, 15.0, 80.0, \n    # CNO\n    1.5,   3.5,  1.0,  \n    # Metals\n    1.0,   1.0,  1.5,  1.0,  1.0,  1.0,  \n    1.5,   1.5,  1.0,  1.5,  2.0,  3.5,  \n    1.5,   2.0\n]\n\nbounds_low = tf.constant(lower_bounds, dtype=tf.float32)\nbounds_high = tf.constant(upper_bounds, dtype=tf.float32)","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-03-13T13:37:06.977674Z","iopub.execute_input":"2026-03-13T13:37:06.977955Z","iopub.status.idle":"2026-03-13T13:37:06.984927Z","shell.execute_reply.started":"2026-03-13T13:37:06.977921Z","shell.execute_reply":"2026-03-13T13:37:06.984072Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Bijector to map Unconstrained space (HMC proposals) -> Bounded space (Physical Labels)\nunconstrained_to_physical = tfb.Chain([\n    tfb.Shift(shift=bounds_low),\n    tfb.Scale(scale=(bounds_high - bounds_low)),\n    tfb.Sigmoid()\n])\n\n# To initialize the HMC, we will need the inverse to map your initial guesses into the latent space\nphysical_to_unconstrained = tfb.Invert(unconstrained_to_physical)\n\n# STD_TENSOR[:N_LABELS_RAW] gives the 23 physical-space standard deviations\n\n\n\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-13T13:37:06.985754Z","iopub.execute_input":"2026-03-13T13:37:06.985991Z","iopub.status.idle":"2026-03-13T13:37:07.004772Z","shell.execute_reply.started":"2026-03-13T13:37:06.985967Z","shell.execute_reply":"2026-03-13T13:37:07.003968Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import tensorflow as tf\nimport tensorflow_probability as tfp\nimport numpy as np\n\n","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-03-13T13:37:07.006494Z","iopub.execute_input":"2026-03-13T13:37:07.006738Z","iopub.status.idle":"2026-03-13T13:37:07.019202Z","shell.execute_reply.started":"2026-03-13T13:37:07.006716Z","shell.execute_reply":"2026-03-13T13:37:07.018395Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"im