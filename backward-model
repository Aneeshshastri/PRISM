 : (batch_stars, 8575)\n    physical_init : (batch_stars, 23) optional warm start in physical units\n\n    Returns\n    -------\n    medians      : (batch_stars, 23)  — posterior median, physical units\n    lower_sigma  : (batch_stars, 23)  — median − 16th percentile\n    upper_sigma  : (batch_stars, 23)  — 84th percentile − median\n    accept_rate  : float\n    r_hat        : (23,)  — Gelman-Rubin per label (should be < 1.01)\n    \"\"\"\n    batch_stars = tf.shape(obs_flux)[0]\n    obs_flux    = tf.cast(obs_flux,  tf.float32)\n    obs_ivar    = tf.cast(obs_ivar,  tf.float32)\n\n    init_state  = make_init_state(\n        batch_stars.numpy(), NUM_CHAINS, physical_init\n    )                                                  # (C, B, 23) physical\n\n    # Map initial state to unconstrained space for NUTS\n    init_unconstrained = physical_to_unconstrained(init_state)\n\n    def log_prob_closure(theta_unconstrained):\n        # theta_unconstrained: (C, B, 23)\n        # bijector maps back to physical before evaluating likelihood\n        theta_physical = unconstrained_to_physical(theta_unconstrained)\n        return target_log_prob_fn(theta_physical, obs_flux, obs_ivar)\n\n    initial_step_size = tf.fill([N_LABELS_RAW], 0.05)\n\n    nuts = tfp.mcmc.NoUTurnSampler(\n        target_log_prob_fn=log_prob_closure,\n        step_size=initial_step_size,\n        max_tree_depth=MAX_TREE_DEPTH,\n    )\n\n    adaptive_kernel = tfp.mcmc.DualAveragingStepSizeAdaptation(\n        inner_kernel=nuts,\n        num_adaptation_steps=NUM_ADAPT,\n        target_accept_prob=TARGET_ACCEPT,\n        step_size_setter_fn=lambda pkr, s: pkr._replace(step_size=s),\n        step_size_getter_fn=lambda pkr: pkr.step_size,\n        log_accept_prob_getter_fn=lambda pkr: pkr.log_accept_ratio,\n    )\n\n    @tf.function(jit_compile=True)\n    def sample():\n        return tfp.mcmc.sample_chain(\n            num_results=NUM_RESULTS,\n            num_burnin_steps=NUM_BURNIN,\n            current_state=init_unconstrained,\n            kernel=adaptive_kernel,\n            trace_fn=lambda _, pkr: (\n                pkr.inner_results.is_accepted,        # (C, B)\n                pkr.inner_results.step_size,          # (23,)\n            ),\n        )\n\n    # samples shape: (num_results, num_chains, batch_stars, 23) — unconstrained\n    samples_unc, (is_accepted, _) = sample()\n\n    # Map samples back to physical space for reporting\n    samples_phys = unconstrained_to_physical(samples_unc)\n    # shape: (num_results, num_chains, batch_stars, 23)\n\n    # --- Gelman-Rubin per label (average over stars for a global convergence check) ---\n    # tfp expects (num_results, num_chains, ...) which is what we have\n    r_hat_per_star = tfp.mcmc.diagnostic.potential_scale_reduction(\n        samples_phys, independent_chain_ndims=1\n    )\n    # r_hat_per_star: (batch_stars, 23) → take mean over stars\n    r_hat = tf.reduce_mean(r_hat_per_star, axis=0).numpy()   # (23,)\n\n    # --- Pool chains for percentile computation ---\n    # (num_results, num_chains, batch_stars, 23)\n    # → (num_results * num_chains, batch_stars, 23)\n    n_total = NUM_RESULTS * NUM_CHAINS\n    flat = tf.reshape(\n        tf.transpose(samples_phys, [0, 1, 2, 3]),\n        [n_total, batch_stars.numpy(), N_LABELS_RAW]\n    )\n\n    pcts = tfp.stats.percentile(flat, [16.0, 50.0, 84.0], axis=0)\n    # pcts: (3, batch_stars, 23)\n\n    medians     = pcts[1].numpy()                # (B, 23)\n    lower_sigma = (pcts[1] - pcts[0]).numpy()    # (B, 23)\n    upper_sigma = (pcts[2] - pcts[1]).numpy()    # (B, 23)\n\n    accept_rate = tf.reduce_mean(\n        tf.cast(is_accepted, tf.float32)\n    ).numpy()\n\n    return medians, lower_sigma, upper_sigma, accept_rate, r_hat","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T06:19:30.415853Z","iopub.execute_input":"2026-03-11T06:19:30.416063Z","iopub.status.idle":"2026-03-11T06:19:30.430068Z","shell.execute_reply.started":"2026-03-11T06:19:30