Chi2 per pixel\n        \n        residuals_sq = (y_pred_b - y_true_b)**2\n        chi_sq_per_pixel = residuals_sq / variance_total\n        \n        # 4. Zero out the Invalid Pixels\n        # This removes the \"garbage\" values from the division by zero\n        chi_sq_per_pixel = chi_sq_per_pixel * valid_mask\n        \n        # 5. Sum and Normalize\n        # Sum only the valid pixels\n        chi_sq_sum = np.sum(chi_sq_per_pixel, axis=1)\n        \n        # Calculate correct degrees of freedom per star\n        n_valid_pixels = np.sum(valid_mask, axis=1)\n        n_params = len(selected_labels)\n        dof = np.maximum(n_valid_pixels - n_params, 1) # Avoid dof=0\n        \n        # Final Reduced Chi2\n        reduced_chi_2[start:end] = chi_sq_sum / dof\n        \n        if k % 2 == 0:\n            print(f\"Batch {k}/{n_batches} done.\")\n\n    return reduced_chi_2\n\n\ntest_chi2=reduced_chi_square(real_data,gen_data,real_data_ivar,\n                             tf.convert_to_tensor(labels[config.start:config.end],dtype=tf.float32),\n                             tf.convert_to_tensor(label_err[config.start:config.end],dtype=tf.float32),batch_size=512)\n\ntest_chi2_P=reduced_chi_square(real_data,gen_data_P,real_data_ivar,\n                             tf.convert_to_tensor(labels[config.start:config.end],dtype=tf.float32),\n                             tf.convert_to_tensor(label_err[config.start:config.end],dtype=tf.float32),batch_size=512,model=ThePayne)\n\ntest_chi2_EP=reduced_chi_square(real_data,gen_data_EP[:,:,0],real_data_ivar,\n                             tf.convert_to_tensor(labels[config.start:config.end],dtype=tf.float32),\n                             tf.convert_to_tensor(label_err[config.start:config.end],dtype=tf.float32),batch_size=512,model=ExpandedPayne)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-07T14:57:12.214016Z","iopub.execute_input":"2026-03-07T14:57:12.214268Z","iopub.status.idle":"2026-03-07T14:59:17.603583Z