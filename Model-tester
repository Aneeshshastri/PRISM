_real_ivar[:, valid_col_mask].copy()\n    print(\"Local Sanitization: Cleaning sporadic artifacts...\")\n    \n    # Identify individual pixels in the REAL data that are outliers\n    outlier_mask = (X_real_masked > UPPER_LIMIT) | (X_real_masked < LOWER_LIMIT)\n    \n    # Count how many pixels we are fixing\n    n_outliers = np.sum(outlier_mask)\n    print(f\"  > Found {n_outliers} sporadic bad pixels in Real Data.\")\n  \n        # Calculate the median of each column (wavelength)\n    col_medians = np.nanmedian(X_real_masked, axis=0)\n        \n        # Get coordinates of bad pixels\n    rows, cols = np.where(outlier_mask)\n    kai=((X_real_masked-X_gen_masked)**2)/(1/X_real_maskedvar+1e-5)\n    print(\"calculate pixelwise error\")\n    print(f\"MAE:{np.mean(np.abs(X_real_masked-X_gen_masked)[~outlier_mask])}\")\n    print(f\"mean_kai: {np.mean(kai)}\")\n    print(f\"RMS:{np.sqrt(np.mean(np.square(X_real_masked-X_gen_masked)[~outlier_mask]))}\")\n        \n        # 1. Fix Real Data (Neutralize the artifact)\n    X_real_masked[rows, cols] = col_medians[cols]\n    X_gen_masked[rows, cols] = col_medians[cols]\n        \n    print(\"Applied mask to BOTH Real and Gen datasets (Fair Comparison).\")\n\n    # --- INSERT THIS BETWEEN STEP 2 AND STEP 3 ---\n    print(\"Fairness Check: Injecting synthetic noise to match APOGEE SNR...\")\n    \n    # 1. Estimate Noise Level from Real Data (using a flat continuum region if possible)\n    # Or use a robust estimator like Median Absolute Deviation (MAD)\n    # sigma ~ 1.4826 * MAD\n    diffs = np.diff(X_real_masked, axis=1)\n    estimated_noise_sigma = 1.4826 * np.nanmedian(np.abs(diffs - np.nanmedian(diffs))) / np.sqrt(2)\n    \n    print(f\" > Estimated Noise Sigma: {estimated_noise_sigma:.5f}\")\n\n    # 2. Add Noise to Generated Data\n    # This simulates the telescope's imperfect view\n    noise = np.random.normal(0, estimated_noise_sigma, X_gen_masked.shape)\n    X_gen_masked_noisy = X_gen_masked+noise\n    \n    # Update the variable to be used in PCA\n    X_gen_masked = X_gen_masked_noisy\n\n   # run_deep_pca_diagnostics(X_real_masked,X_gen_masked,np.logspace(np.log10(1514),np.log10(1694),8575))\n    # --- STEP 3: Fit PCA ---\n    print(\"--- Running Deep PCA Diagnostics ---\")\n    \n    # 1. Fit PCA with MORE components to see the 'tail'\n    # We use 20 components to capture ~95%+ of variance usually\n    n_comps = 20\n    pca_real = PCA(n_components=n_comps)\n    pca_gen = PCA(n_components=n_comps)\n    \n    # Fit separately to compare internal structures\n    pca_real.fit(X_real_masked)\n    pca_gen.fit(X_gen_masked)\n    \n    # --- PLOT 1: Eigenvalues (The Scree Plot) ---\n    #plt.style.use('dark_background') \n    plt.figure(figsize=(12, 5))\n    \n    # Cumulative Variance\n    real_cum_var = np.cumsum(pca_real.explained_variance_ratio_)\n    gen_cum_var = np.cumsum(pca_gen.explained_variance_ratio_)\n  \n    plt.subplot(1, 2, 1)\n    plt.plot(range(1, n_comps+1), real_cum_var, 'b-o', label='Real Data', markersize=4)\n    plt.plot(range(1, n_comps+1), gen_cum_var, 'r--x', label='Generated Data', markersize=4)\n    plt.axhline(0.95, color='k', linestyle=':', alpha=0.5, label='95% Variance')\n    plt.title(\"Cumulative Explained Variance (Noise augmented gendata)\")\n    plt.xlabel(\"Number of Components\")\n    plt.ylabel(\"Total Variance Explained\")\n    plt.legend()\n    plt.grid(True, alpha=0.3)\n\n    \n    print(\"Fitting PCA on Cleaned Real Data...\")\n    pca = PCA(n_components=2)\n    \n    # Fit on real data, transform both\n    real_embedded = pca.fit_transform(X_real_masked)\n    gen_embedded = pca.transform(X_gen_masked)\n\n    # --- STEP 4: Reporting & Plotting ---\n    var_ratio = pca.explained_variance_ratio_\n    print(f\"\\nexplained_variance_ratio: PC1={var_ratio[0]*100:.1f}%, PC2={var_ratio[1]*100:.1f}%\")\n    print(f\"Total Variance Captured: {np.sum(var_ratio)*100:.1f}%\")\n\n    plt.subplot(1,2,2)\n    \n    # Plot Real Data (Blue)\n\n    plt.sca